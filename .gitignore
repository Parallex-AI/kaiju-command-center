# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Environment variables
.env

# Local runtime artifacts
logs/
temp/

# MemPalace generated client memory (runtime output — not committed)
memory/client-memory/

# OpenClaw runtime audit log (runtime output — not committed)
openclaw/audit/

# Credential reference runtime store (reference metadata only — not secrets, but not committed)
runtime/credential-references/

# macOS
.DS_Store
