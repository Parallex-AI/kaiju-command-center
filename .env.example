# Kaiju Command Center — environment variable template
#
# Copy this file to .env for local development:
#   cp .env.example .env
#
# NEVER commit .env — it is gitignored.
# NEVER put real secrets, tokens, or API keys in this file.
# In production, secrets are sourced from GCP Secret Manager.
#
# Full reference: docs/ENVIRONMENT_VARIABLES.md

# ---------------------------------------------------------------------------
# OpenClaw runtime environment
# Values: local | staging | production
# ---------------------------------------------------------------------------
OPENCLAW_ENV=local

# ---------------------------------------------------------------------------
# HTTP server port
# Cloud Run sets PORT automatically — do not hardcode in production.
# ---------------------------------------------------------------------------
PORT=8100

# ---------------------------------------------------------------------------
# API key authentication (placeholder — disabled by default)
# Set OPENCLAW_API_AUTH_ENABLED=true and provide keys to enable.
# In production, OPENCLAW_API_KEYS is sourced from GCP Secret Manager.
# ---------------------------------------------------------------------------
OPENCLAW_API_AUTH_ENABLED=false
OPENCLAW_API_KEYS=

# ---------------------------------------------------------------------------
# CORS allowed origins
# Use "*" for local permissive mode.
# In production, set explicit origins:
#   OPENCLAW_ALLOWED_ORIGINS=https://app.kaiju.digital,https://admin.kaiju.digital
# ---------------------------------------------------------------------------
OPENCLAW_ALLOWED_ORIGINS=*

# ---------------------------------------------------------------------------
# Tenant context
# ---------------------------------------------------------------------------
OPENCLAW_DEFAULT_TENANT=demo-client
OPENCLAW_REQUIRE_TENANT_HEADER=false

# ---------------------------------------------------------------------------
# Audit log
# OPENCLAW_AUDIT_ROOT is repo-relative by default.
# In production (Cloud Run), container filesystem is ephemeral —
# use Cloud Logging or a GCS-mounted path for durable audit storage.
# ---------------------------------------------------------------------------
OPENCLAW_AUDIT_ENABLED=true
OPENCLAW_AUDIT_ROOT=openclaw/audit

# ---------------------------------------------------------------------------
# MemPalace client memory
# MEMORY_ROOT is repo-relative by default.
# In production, set MEMORY_ENABLED=false until a durable backend
# (Firestore / Cloud Storage) is configured.
# ---------------------------------------------------------------------------
MEMORY_ENABLED=true
MEMORY_ROOT=memory/client-memory
MEMORY_MAX_RECENT_SNAPSHOTS=5
MEMORY_STORE_RAW_PAYLOADS=false

# ---------------------------------------------------------------------------
# n8n Ads Agent webhook
# In production, N8N_ADS_WEBHOOK_URL is sourced from GCP Secret Manager.
# Leave empty here — do not commit the real URL if it contains auth tokens.
# ---------------------------------------------------------------------------
N8N_ADS_WEBHOOK_URL=
N8N_WEBHOOK_TIMEOUT=15

# ---------------------------------------------------------------------------
# Ads Agent execution mode
# Values: graph | legacy
# ---------------------------------------------------------------------------
ADS_AGENT_EXECUTION_MODE=graph

# ---------------------------------------------------------------------------
# Google Ads integration (V4.4+)
# ADS_DATA_SOURCE selects the data source adapter.
# Values: n8n_demo (default) | mock_fixture | google_ads
# ---------------------------------------------------------------------------
ADS_DATA_SOURCE=n8n_demo

# ---------------------------------------------------------------------------
# Google Ads live flag
# Set to true only after configuring all credential variables below.
# Default false prevents any live API calls.
# ---------------------------------------------------------------------------
GOOGLE_ADS_LIVE_ENABLED=false

# ---------------------------------------------------------------------------
# Google Ads credentials
# All are SECRET — do not commit real values.
# In production, source from GCP Secret Manager.
# Required only when GOOGLE_ADS_LIVE_ENABLED=true.
# ---------------------------------------------------------------------------
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=
